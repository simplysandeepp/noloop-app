# NoLoop AI engine — optional config.
#
# The engine is fully deterministic without any of these set. Provide a Groq
# key (free tier, very fast) to have an LLM rewrite each rationale in plain
# language. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
NOLOOP_LLM_MODEL=llama-3.3-70b-versatile
